{
  "name": "rafraser",
  "version": "1.0.0",
  "description": "Yet another static site generator",
  "main": "index.js",
  "scripts": {
    "build": "tsc && npm run lint",
    "lint": "tsc --noEmit",
    "static-build": "npm run static-sass & node dist/static/build.js",
    "static-clean": "rm -rf static-build",
    "static-sass": "sass static-content/sass:static-build/assets/style",
    "static-all": "npm run static-clean && npm run static-build",
    "serve": "node dist/server.js"
  },
  "keywords": [],
  "author": "Robert A Fraser",
  "license": "ISC",
  "dependencies": {
    "express": "^4.17.1",
    "liquidjs": "^9.19.0",
    "marked": "^1.2.7",
    "typescript": "^4.1.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.9",
    "@types/marked": "^1.2.1",
    "@types/node": "^14.14.14"
  }
}
